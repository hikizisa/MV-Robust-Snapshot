<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>MapsetVerifier.Plugin.CustomSnapshots</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="MV-Robust-Snapshot.Tests\**" />
  </ItemGroup>

  <ItemGroup>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleToAttribute">
      <_Parameter1>MV-Robust-Snapshot.Tests</_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>

  <ItemGroup>
    <Reference Include="MapsetVerifier.Framework">
      <HintPath>lib/MapsetVerifier.Framework.dll</HintPath>
    </Reference>
    <Reference Include="MapsetVerifier.Snapshots">
      <HintPath>lib/MapsetVerifier.Snapshots.dll</HintPath>
    </Reference>
    <Reference Include="MapsetVerifier.Parser">
      <HintPath>lib/MapsetVerifier.Parser.dll</HintPath>
    </Reference>
    <Reference Include="MapsetVerifier.Logging">
      <HintPath>lib/MapsetVerifier.Logging.dll</HintPath>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="MathNet.Numerics" Version="5.0.0" />
    <PackageReference Include="Serilog" Version="4.3.1" />
  </ItemGroup>

  <Target Name="CopyToCustomChecks" AfterTargets="Build" Condition="'$(SkipCustomChecksCopy)' != 'true'">
    <Copy SourceFiles="$(OutputPath)$(AssemblyName).dll" DestinationFolder="$(APPDATA)\Mapset Verifier Externals\CustomChecks" />
  </Target>
</Project>
